{
  "name": "@zhenyk/autoreview",
  "version": "2.0.2",
  "description": "Frontend performance testing and analytics CLI tool for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "autoreview": "./dist/cli/index.js"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "start": "node ./dist/cli/index.js",
    "dev": "tsx watch ./src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "lighthouse": "^12.0.0",
    "ora": "^7.0.0",
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "performance",
    "testing",
    "web-vitals",
    "lighthouse",
    "frontend",
    "cli",
    "fps",
    "memory",
    "profiling",
    "chrome-devtools"
  ],
  "author": "shadowkun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shadowkun/autoReview.git"
  },
  "bugs": {
    "url": "https://github.com/shadowkun/autoReview/issues"
  },
  "homepage": "https://github.com/shadowkun/autoReview#readme",
  "publishConfig": {
    "access": "public"
  }
}
